# ===========================================
# PUMP.FUN AUTO TP/SL BOT CONFIGURATION
# ===========================================

# Wallet Configuration
PUMP_WALLET_ADDRESS=YourWalletAddressHere111111111111111111111111

# Private Key (base58 encoded) - REQUIRED for actual trading
# Leave empty for DRY RUN mode (monitoring only)
PUMP_PRIVATE_KEY=

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# RPC Configuration
# Get free API key from https://helius.dev
HELIUS_API_KEY=your_helius_api_key

# Alternative RPC (if not using Helius)
RPC_URL=https://api.mainnet-beta.solana.com

# ===========================================
# TAKE PROFIT & STOP LOSS SETTINGS
# ===========================================

# Take Profit Levels (comma separated percentages)
# Bot will sell portion of position at each level
# Example: 5,10,15,20,25 = sell 20% at each level
TP_LEVELS=5,10,15,20,25

# Stop Loss Percentage
# Bot will close entire position if loss exceeds this
SL_LEVEL=10

# Check Interval (seconds)
# How often to check positions
CHECK_INTERVAL=30

# ===========================================
# NOTES
# ===========================================
# 
# 1. DRY RUN MODE:
#    - If PUMP_PRIVATE_KEY is empty, bot runs in monitoring mode
#    - No actual trades will be executed
#    - Use this to test before adding private key
#
# 2. TAKE PROFIT BEHAVIOR:
#    - At each TP level, bot sells (100/num_levels)% of position
#    - Example with 5 levels: sells 20% at each level
#    - Once a TP level is triggered, it won't trigger again
#
# 3. STOP LOSS BEHAVIOR:
#    - Closes entire remaining position immediately
#    - Resets position tracking for that token
#
# 4. TELEGRAM SETUP:
#    - Create bot via @BotFather
#    - Get chat ID by messaging bot and checking:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
